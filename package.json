{
  "name": "@jeremy-albinet/stitch-revitalized-for-roku",
  "scripts": {
    "build": "bsc --createPackage=false",
    "watch": "npm run build -- --watch",
    "package": "bsc --create-package",
    "lint": "bslint",
    "lint:fix": "bslint --fix",
    "fmt": "brighterscript-formatter --write 'source/**/*.{brs,bs}' 'components/**/*.{brs,bs}'",
    "fmt:check": "brighterscript-formatter --check 'source/**/*.{brs,bs}' 'components/**/*.{brs,bs}'",
    "test": "bsc --project bsconfig.test.json --create-package && node tools/deploy-test.js",
    "prepare": "husky",
    "sign": "node scripts/sign-package.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@rokucommunity/bslint": "^0.8.42",
    "brighterscript-formatter": "^1.7.24",
    "husky": "^9.1.7",
    "rooibos-roku": "^5.16.1",
    "ropm": "^0.11.5"
  },
  "dependencies": {
    "brighterscript": "0.72.0"
  },
  "overrides": {
    "form-data": "^4.0.5",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "lodash": "4.18.1",
    "@xml-tools/common": {
      "lodash": "4.18.1"
    },
    "@xml-tools/ast": {
      "lodash": "4.18.1"
    }
  }
}
