{
    "name": "@jeremy-albinet/stitch-revitalized-for-roku",
    "scripts": {
        "build": "bsc --createPackage=false",
        "watch": "npm run build -- --watch",
        "package": "bsc --create-package",
        "lint": "bslint",
        "lint:fix": "bslint --fix",
        "fmt": "brighterscript-formatter --write '**/*.{brs,bs}'",
        "fmt:check": "brighterscript-formatter --check '**/*.{brs,bs}'"
    },
    "devDependencies": {
        "@rokucommunity/bslint": "^0.8.41",
        "brighterscript-formatter": "^1.7.19",
        "ghooks": "^2.0.4",
        "ropm": "^0.11.5"
    },
    "dependencies": {
        "brighterscript": "^0.71.0"
    },
    "config": {
        "ghooks": {
            "pre-commit": ""
        }
    },
    "overrides": {
        "form-data": "^4.0.5",
        "qs": "^6.14.1",
        "tough-cookie": "^4.1.3",
        "lodash": "4.18.1",
        "@xml-tools/common": {
            "lodash": "4.18.1"
        },
        "@xml-tools/ast": {
            "lodash": "4.18.1"
        }
    }
}
