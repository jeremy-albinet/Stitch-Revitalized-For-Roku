{
  "name": "@jeremy-albinet/stitch-revitalized-for-roku",
  "scripts": {
    "build": "bsc --createPackage=false",
    "watch": "npm run build -- --watch",
    "package": "bsc --create-package",
    "lint": "bslint",
    "lint:fix": "bslint --fix",
    "fmt": "brighterscript-formatter --write '**/*.{brs,bs}'",
    "fmt:check": "brighterscript-formatter --check '**/*.{brs,bs}'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@rokucommunity/bslint": "^0.8.41",
    "brighterscript-formatter": "^1.7.19",
    "husky": "^9.1.7",
    "ropm": "^0.11.5"
  },
  "dependencies": {
    "brighterscript": "^0.71.0"
  },
  "overrides": {
    "form-data": "^4.0.5",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "lodash": "4.18.1",
    "@xml-tools/common": {
      "lodash": "4.18.1"
    },
    "@xml-tools/ast": {
      "lodash": "4.18.1"
    }
  }
}
