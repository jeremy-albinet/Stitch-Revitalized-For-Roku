<?xml version="1.0" encoding="utf-8"?>

<component name="TileRow" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentChange" />
        <field id="itemFocused" type="int" value="-1" />
        <field id="itemSelected" type="int" value="-1" />
        <field id="itemComponentName" type="string" value="VideoItem" onChange="onItemComponentNameChange" />
        <field id="jumpToItem" type="int" value="-1" onChange="onJumpToItemChange" />
    </interface>
    <children>
        <Poster id="focusGlow" opacity="0" />
        <Group id="scaleWrapper">
            <RowList id="rowList" />
        </Group>
    </children>
    <script type="text/brightscript" uri="TileRow.brs" />
</component>