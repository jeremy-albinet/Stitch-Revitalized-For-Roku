<?xml version="1.0" encoding="utf-8"?>
<component name="ChannelPage" extends="SceneManagerGroup">
    <interface>
        <field id="contentRequested" type="node" onChange="updatePage" />
        <field id="backgroundColor" type="string" alias="background.color, background2.color" />
        <field id="selectedItem" type="node" />
        <field id="chatStarted" type="bool" value="false" />
        <field id="fullScreenChat" type="bool" value="false" onChange="fullScreenChat" />
        <field id="finished" type="bool" />
        <field id="cameFromLogin" type="bool" value="false" />
    </interface>
    <script type="text/brightscript" uri="ChannelPage.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/misc.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/contentBuilder.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/config.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/taskFactory.brs" />
    <children>
        <rectangle id="background" width="1280" height="720" />
        <Group id="banner" translation="[0, 0]"></Group>
        <rectangle id="background2" width="1280" height="720" translation="[0, 214]" />
        <Group id="container" translation="[ 20, 10 ]">
            <Group id="profile" translation="[0,140]">
                <CirclePoster id="avatar" width="150" height="150" />
                <!-- <MaskGroup id="profileImageMask" maskuri="pkg:/images/profile-mask-150.png"
                    maskSize="[226,226]" maskOffset="[0,0]">
                    <Poster id="avatar" width="150" height="150" />
                </MaskGroup> -->
                <SimpleLabel
                    id="username"
                    fontSize="24"
                    fontUri="pkg:/fonts/Archivo-Bold.otf"
                    translation="[160,60]" />
                <SimpleLabel
                    id="followers"
                    fontSize="16"
                    fontUri="pkg:/fonts/Archivo-Regular.otf"
                    translation="[160,85]" />

            </Group>
            <ChannelMenu id="channelMenu" translation="[700,180]" visible="false" />
            <Group id="about" translation="[450,25]">
                <InfoPane
                    visible="false"
                    id="description"
                    width="600"
                    translation="[20,0]" />
            </Group>
            <RowList
                id="homeRowList"
                rowLabelOffset="[[0,5]]"
                rowLabelFont="font:LargeBoldSystemFont"
                translation="[ 30,350 ]"
                itemComponentName="VideoItem"
                numRows="4"
                rowItemSize="[[320,180]]"
                rowItemSpacing="[[30,0]]"
                itemSize="[1980, 295]"
                itemSpacing="[ 0, 40 ]"
                showRowLabel="[ true ]"
                focusBitmapUri="pkg:/images/focusindicator.9.png"
                vertFocusAnimationStyle="fixedFocus"
                rowFocusAnimationStyle="fixedFocus"
            />
        </Group>
        <Poster id="focusindicator" uri="pkg:/images/focusindicator.9.png" translation="[28,320]" width="1224" height="392" visible="false" />
        <Chat id="chat" translation="[30,330]" backgroundColor="0x000000ff" width="1220" height="380" visible="false" forceLive="true" />
    </children>

</component>
