<?xml version="1.0" encoding="utf-8"?>
<component name="GamePage" extends="SceneManagerGroup" initialFocus="homeRowList">
    <interface>
        <field id="contentRequested" type="node" onChange="updatePage" />
        <field id="backgroundColor" type="string" alias="background.color" />
        <field id="pageTitle" type="string" alias="Header.text" />
    </interface>
    <script type="text/brightscript" uri="GamePage.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/misc.brs" />
    <children>
        <rectangle id="background" width="1280" height="720" color="0x0e0e10FF" />
        <Label
            id="Header"
            translation="[130, 90]"
            text="Browse"
            color="0xEFEFF1FF"
            height="40"
            width="400">
            <Font role="font" uri="pkg:/fonts/Archivo-Bold.otf" size="28" />
        </Label>
        <Rectangle
            id="titleSeparator"
            translation="[130, 133]"
            width="1080"
            height="1"
            color="0x3b3b44FF" />
        <RowList
            id="homeRowList"
            visible="true"
            rowLabelOffset="[[0,5]]"
            rowLabelFont="font:LargeBoldSystemFont"
            translation="[ 130, 140 ]"
            itemComponentName="VideoItem"
            numRows="4"
            rowItemSize="[[320,180]]"
            rowItemSpacing="[[30,0]]"
            itemSize="[1280,295]"
            itemSpacing="[ 0, 40 ]"
            showRowLabel="[ false ]"
            rowHeights="[235]"
            focusBitmapUri="pkg:/images/focusIndicator.9.png"
            vertFocusAnimationStyle="fixedFocus"
            rowFocusAnimationStyle="floatingFocus"
        />
    </children>

</component>