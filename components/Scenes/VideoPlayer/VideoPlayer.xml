<?xml version="1.0" encoding="utf-8"?>
<component name="VideoPlayer" extends="SceneManagerGroup" initialFocus="videoWindow">
    <interface>
        <field id="contentRequested" type="Node" onChange="handleContent" />
        <field id="contentStore" type="assocarray" />
        <field id="metadata" type="array" />
        <field id="content" type="node" />

        <!-- state - Same as Task states. -->
        <field id="state" type="string" alwaysNotify="true" />

        <!-- control - "play" starts content playback -->
        <field id="control" type="string" alwaysNotify="true" onChange="controlChanged" />
        <field id="streams" type="assocarray" />
        <field id="ChatStarted" type="bool" value="false" />
    </interface>
    <script type="text/brightscript" uri="VideoPlayer.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/misc.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/config.brs" />
    <children>
        <Chat
            id="chat"
            visible="false"
            translation="[960,0]"
            forceLive="false" />
        <TwitchApiTask
            functionName="getTwitchBookmarks"
            control="run"
        />
        <!-- Chat compose overlay (hidden by default) -->
        <Group id="chatComposeOverlay" visible="false" translation="[0,0]">
            <Rectangle width="1280" height="720" color="0x000000BF" />
            <Group translation="[190,200]">
                <!-- Card shadow/border -->
                <Rectangle width="904" height="370" color="0x9147FF33" />
                <!-- Main card -->
                <Rectangle
                    translation="[2, 2]"
                    width="900"
                    height="366"
                    color="0x18181BFF" />
                <!-- Purple accent bar at top of card -->
                <Rectangle
                    translation="[2, 2]"
                    width="900"
                    height="4"
                    color="0x9147FFFF" />
                <!-- Header icon + title -->
                <Poster
                    translation="[20, 20]"
                    uri="pkg:/images/icons/comments.png"
                    width="22"
                    height="22" />
                <SimpleLabel
                    translation="[50, 18]"
                    text="Send a message"
                    color="0xEFEFF1FF"
                    fontSize="18"
                    fontUri="pkg:/fonts/Archivo-Bold.otf" />
                <!-- Emote picker shortcut hint -->
                <SimpleLabel
                    translation="[690, 20]"
                    text="✸ for emotes"
                    color="0x808080FF"
                    fontSize="14"
                    fontUri="pkg:/fonts/Archivo-Regular.otf" />
                <!-- Separator -->
                <Rectangle
                    translation="[20, 52]"
                    width="860"
                    height="1"
                    color="0x3b3b44FF" />
                <DynamicMiniKeyboard
                    id="chatComposeKeyboard"
                    translation="[20,66]"
                    buttonHeight="28" />
            </Group>
        </Group>
        <!-- Emote picker overlay (hidden by default) -->
        <EmotePicker id="emotePickerOverlay" visible="false" />
    </children>

</component>