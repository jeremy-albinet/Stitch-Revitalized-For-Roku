# fmp4-demux-proxy environment variables
# Copy to .env and adjust for your setup.

# Port the HTTP server listens on.
PORT=8080

# Log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Public base URL of this proxy as seen by the Roku device.
# Required when the proxy runs behind a reverse proxy or in Docker with port mapping,
# and the auto-detected URL (scheme + Host header) is wrong.
# Example: PROXY_PUBLIC_URL=http://192.168.1.50:8080
# Default: auto-detected from the incoming request (works for most setups).
PROXY_PUBLIC_URL=

# Seconds to wait for the upstream TCP connection to Twitch CDN.
UPSTREAM_CONNECT_TIMEOUT=5.0

# Seconds to wait for upstream response bytes.
UPSTREAM_READ_TIMEOUT=30.0
